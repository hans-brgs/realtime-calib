# =============================================================================
# realtime-calib — environment variables (template)
# Copy to `.env` (gitignored) and fill in. NEVER commit `.env`.
# `.env` is the source of secrets, propagated to services by docker-compose.
# =============================================================================

# --- Network / host (ADR-0014) --------------------------------------------
# Host machine IP on the LAN, used by Caddy (TLS), LiveKit and the webapp
# build. Set to the real IP of the PC (e.g. 192.168.1.42).
HOST_IP=192.168.1.42

# --- LiveKit (ADR-0004) ----------------------------------------------------
# Key/secret of the local LiveKit instance. Generate a dedicated pair
# (do not reuse keys from another project). In dev, livekit-server accepts
# an arbitrary pair declared here.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=changeme-secret-min-32-chars-long
LIVEKIT_ROOM_NAME=calibration

# LiveKit server URL as seen by calibration-service. Inside docker-compose it
# reaches LiveKit over the shared bridge at ws://livekit:7880. Override only when
# running calibration-service outside compose (then point at the host, e.g.
# ws://localhost:7880).
LIVEKIT_URL=ws://livekit:7880

# --- calibration-service (CALIB_*, see service CLAUDE.md) ------------------
CALIB_HTTP_HOST=0.0.0.0
CALIB_HTTP_PORT=8000
# Root of the session folders = source of truth (ADR-0011).
CALIB_SESSIONS_DIR=/data/sessions
# Camera capture backend (V4L2 on Linux).
CALIB_CAMERA_BACKEND=v4l2
# OpenBLAS kernel pin — workaround for SIGILL crashes in cv2.calibrateCamera on
# some AVX-512 CPUs. The service already defaults this to "Haswell" itself, set
# before the first numpy import (it cannot go through the Config class, which
# imports numpy). Uncomment to override per host; it must be present in the
# process environment before launch. See RUNBOOK.md troubleshooting.
#OPENBLAS_CORETYPE=Haswell

# --- livekit-token-server --------------------------------------------------
TOKEN_SERVER_PORT=8080

# --- Host port overrides (optional) ----------------------------------------
# Override only to avoid clashes with another local stack.
CADDY_HTTPS_PORT=443
# LiveKit media ports (published 1:1, reachable at HOST_IP) are fixed in
# docker-compose.yml / livekit.yaml: UDP 50000-50010 + TCP 7881. Change them
# there if they clash with another LiveKit on the host.

# --- Webapp (Vite build, VITE_* — exposed to the browser, no secrets) ------
# Set at build time; propagated from HOST_IP. With the `default` profile
# (Caddy+TLS) URLs go through https/wss on HOST_IP; with `local`, localhost.
VITE_HOST_IP=${HOST_IP}
VITE_API_URL=https://${HOST_IP}/api
VITE_LIVEKIT_URL=wss://${HOST_IP}/livekit
VITE_TOKEN_URL=https://${HOST_IP}/token
