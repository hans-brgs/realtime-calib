    given-names: Hans
    email: hans95.bourgeois@gmail.com
    affiliation: Myosin
repository-code: "https://github.com/hans-brgs/realtime-calib"
url: "https://github.com/hans-brgs/realtime-calib"
license: AGPL-3.0-or-later
date-released: "2026-07-09"
keywords:
  - camera calibration
  - multi-camera
  - ChArUco
  - ArUco
  - extrinsic calibration
  - intrinsic calibration
  - computer vision
  - OpenCV
