# Webapp build/runtime config (Vite, VITE_* — exposed to the browser, no secrets).
# Copy to `.env` for local `yarn dev`. Values are propagated from the root HOST_IP.
# With the `default` profile (Caddy+TLS) URLs go through https/wss on HOST_IP;
# with `local`, use localhost.

VITE_HOST_IP=192.168.1.42
VITE_API_URL=https://192.168.1.42/api
VITE_LIVEKIT_URL=wss://192.168.1.42/livekit
VITE_TOKEN_URL=https://192.168.1.42/token
